# Salin ke `.env` lokal (tidak di-commit). Lihat `src/config/env.ts`.

# URL API Satset (tanpa trailing slash)
# Emulator Android: localhost/127.0.0.1 otomatis diganti ke 10.0.2.2 saat dev.
# Device fisik: pakai IP LAN mesin dev, mis. http://192.168.x.x:3000
EXPO_PUBLIC_API_URL=https://api2.arashy.web.id

# OneSignal App ID untuk push kasir
EXPO_PUBLIC_ONESIGNAL_APP_ID=bd1f10c3-5fb6-4f9f-810e-3f42c778ce7d

# Set `true` hanya untuk demo/dev: isi order contoh di MMKV saat kosong.
# Produksi: hapus atau `false` agar tidak ada seed order palsu.
EXPO_PUBLIC_POS_DEMO_SEED=false

# Nama environment dan identitas native app.
# Staging sebaiknya memakai package/bundle id berbeda agar bisa install berdampingan.
EXPO_PUBLIC_APP_NAME=Satset Kasir
EXPO_PUBLIC_APP_SLUG=satset-kasir
EXPO_PUBLIC_APP_SCHEME=sat-set
EXPO_PUBLIC_ANDROID_PACKAGE=com.sisatset.kasir
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.sisatset.kasir
EXPO_PUBLIC_ONESIGNAL_MODE=development

# Opsional setelah project di-link dengan EAS (`eas init`).
EAS_PROJECT_ID=
